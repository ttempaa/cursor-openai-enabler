{
  "name": "cursor-openai-enabler",
  "displayName": "Cursor OpenAI Enabler",
  "description": "Automatically re-enables the OpenAI API Key toggle in Cursor when it randomly resets",
  "version": "0.0.2",
  "publisher": "ttempaa",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "extensionKind": ["ui"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursor-openai-enabler.toggle",
        "title": "Cursor OpenAI Enabler: Toggle On/Off"
      }
    ]
  },
  "scripts": {
    "build": "bun run build.ts",
    "package": "vsce package --allow-missing-repository"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ttempaa/cursor-openai-enabler"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.2.0"
  }
}
