{
	"name": "cursor-openai-enabler",
	"displayName": "Cursor OpenAI Enabler",
	"description": "Automatically re-enables the OpenAI API Key toggle in Cursor when it randomly resets",
	"version": "0.0.6",
	"publisher": "ttempaa",
	"author": "ttempaa",
	"license": "MIT",
	"homepage": "https://github.com/ttempaa/cursor-openai-enabler#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/ttempaa/cursor-openai-enabler"
	},
	"bugs": {
		"url": "https://github.com/ttempaa/cursor-openai-enabler/issues"
	},
	"keywords": [
		"cursor",
		"openai",
		"api-key",
		"automation",
		"fix"
	],
	"categories": [
		"Other"
	],
	"engines": {
		"vscode": "^1.85.0"
	},
	"extensionKind": [
		"ui"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "cursor-openai-enabler.toggle",
				"title": "Cursor OpenAI Enabler: Toggle Extension"
			},
			{
				"command": "cursor-openai-enabler.toggleOpenAIKey",
				"title": "Cursor OpenAI Enabler: Toggle OpenAI Key"
			}
		]
	},
	"scripts": {
		"build": "bun run build.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"package": "vsce package"
	},
	"dependencies": {
		"sql.js": "^1.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.4.0",
		"@types/sql.js": "^1.4.9",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.2.0",
		"typescript": "^5.7.0"
	}
}
